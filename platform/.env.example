# —— 数据库 ——
DATABASE_URI=postgres://lilink:lilink@localhost:5432/lilink

# —— Payload ——
# 生成: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-random-secret

# —— 微信公众号（发布用，第一期联调时填）——
WX_APP_ID=
WX_APP_SECRET=
# 阅读原文默认外链
WX_SOURCE_URL=https://lilink.top

# —— 云对象存储（媒体库，S3 兼容：OSS/COS/R2 均可）——
# 阿里云 OSS 示例（私有桶 + presigned 直链访问，详见 src/lib/oss-presign.ts 与 Media 的 afterRead）：
#   S3_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com  （带 oss- 前缀的地域 endpoint）
#   S3_REGION=ap-southeast-1                              （地域名，不带 oss- 前缀；用于 SDK 签名）
#   S3_BUCKET=your-bucket
# 要点：① OSS 只支持 virtual-hosted（代码已 forcePathStyle:false）；② 桶可保持私有，media.url 由
#   afterRead 生成 1h presigned 直链，无需公共读；③ 用 RAM 子账号时必须授该桶最小权限（oss:GetObject/
#   PutObject/DeleteObject/ListObjects/AbortMultipartUpload/ListParts/GetObjectMeta），否则报
#   forbidden / "bucket does not belong to you"；④ 未配 S3_BUCKET 时自动回落本地磁盘存储。
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
